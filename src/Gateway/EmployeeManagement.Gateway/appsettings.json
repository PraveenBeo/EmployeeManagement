{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  },
  "DownstreamServices": {
    "UserManagementApi": "http://localhost:5001",
    "SystemManagementApi": "http://localhost:5002"
  },
  "ReverseProxy": {
    "Routes": {
      "user-management-route": {
        "ClusterId": "user-management-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/users/{**catch-all}"
          }
        ]
      },
      "system-management-route": {
        "ClusterId": "system-management-cluster",
        "Match": {
          "Path": "/api/system/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/{**catch-all}"
          }
        ]
      },
      "user-swagger-route": {
        "ClusterId": "user-management-cluster",
        "Order": 0,
        "Match": {
          "Path": "/swagger/user/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      },
      "system-swagger-route": {
        "ClusterId": "system-management-cluster",
        "Order": 0,
        "Match": {
          "Path": "/swagger/system/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "user-management-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "system-management-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      }
    }
  }
}
